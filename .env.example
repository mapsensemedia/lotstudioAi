# Set to 1 to use the placeholder ellipse mask (no real segmentation, no API calls).
# Leave unset/0 to use real local vehicle segmentation via @imgly/background-removal-node.
MOCK_MODE=0

STORAGE_DIR=./storage
DATABASE_URL=./storage/lotstudio.db

# OpenAI image generation — required ONLY for AI background presets (ai_showroom, ai_outdoor, ai_luxury).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
