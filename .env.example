# Set to 1 to use the placeholder ellipse mask (no real segmentation, no API calls).
# Leave unset/0 to use real local vehicle segmentation via @imgly/background-removal-node.
MOCK_MODE=0

STORAGE_DIR=./storage
DATABASE_URL=./storage/lotstudio.db

# OpenAI image generation — required ONLY for AI background presets (ai_showroom, ai_outdoor, ai_luxury).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Supabase auth — gates dashboard, jobs, upload, erase, and export.
# Create a project at https://supabase.com, then in Authentication → Providers
# disable "Enable email signups" so only invited users (Authentication → Users → Invite)
# can sign in via the magic-link login page.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Used for the post-signout redirect in production. Locally http://localhost:3000 is fine.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
